# String params for Firebase Functions (loaded on deploy).
# Copy to functions/.env or functions/.env.handyjob-d3464
#
# SQUARE_ENVIRONMENT=sandbox
# Leave unset to use the code default (sandbox).
#
# Thumbtack webhook (Firebase secrets + string param):
#   firebase functions:secrets:set THUMBTACK_WEBHOOK_SECRET
#   THUMBTACK_WEBHOOK_USER=handyjob   # Basic auth username Thumbtack sends
#   CLIENT_APP_ORIGIN=https://handyjob-d3464.web.app   # client invite links in webhook responses
#
# Thumbtack webhook registration (scripts/thumbtackWebhookSetup.mjs):
#   THUMBTACK_ACCESS_TOKEN=...
#   THUMBTACK_BUSINESS_ID=567536553635102723
#   THUMBTACK_WEBHOOK_URL=https://us-central1-handyjob-d3464.cloudfunctions.net/thumbtackWebhook
